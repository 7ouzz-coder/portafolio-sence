<!-- Ventana principal: simula el cliente de Windows Live Messenger -->
<div class="wlm-window" id="wlm-app">
    <div class="resizer resizer-r"></div>
    <div class="resizer resizer-b"></div>
    <div class="resizer resizer-br"></div>
    <div class="resizer resizer-l"></div>
    <div class="resizer resizer-t"></div>

    <div class="title-bar" id="drag-handle">
        <div class="title-bar-drag">
            <div class="title-bar-text">
                <img src="https://upload.wikimedia.org/wikipedia/commons/b/b7/WLM_logo.svg" width="14">
                Windows Live Messenger
            </div>
        </div>
        <div class="controls">
            <button class="btn-min" onclick="minimizeApp()">_</button>
            <button class="btn-max" onclick="maximizeApp('wlm-app')">□</button>
            <button class="btn-close" onclick="closeApp()">X</button>
        </div>
    </div>

    <div class="wlm-menu">
        <span>Archivo</span><span>Contactos</span><span>Acciones</span>
        <span>Herramientas</span><span>Ayuda</span>
    </div>

    <div class="wlm-header">
        <div class="avatar-container">
            <img src="{{aboutData.imageUrl}}" width="64" height="64" style="object-fit:cover">
        </div>
        <div class="user-info">
            <div class="user-name">
                {{siteConfig.brandName}}
                <span style="font-weight:normal; color:#555">(Conectado)</span>
            </div>
            <div class="user-sub">&lt;{{{heroData.subtitle}}}&gt;</div>
            <div class="user-status">Haz clic aqui para cambiar tu estado o tu nombre.</div>
        </div>
    </div>

    <div class="wlm-main">
        <!-- Cada contact-item abre una seccion del portafolio en la ventana de chat -->
        <div class="contact-group">
            <div class="group-title" onclick="toggleGroup('group-portafolio')">Portafolio (5/5)</div>
            <div id="group-portafolio">
                <div class="contact-item" onclick="openChat('about', 'Sobre Mi', '{{siteConfig.brandName}}')">
                    <span class="contact-icon"></span>
                    <span class="contact-name">Sobre Mi</span>
                    <span class="contact-desc">- Conoce mas de mi perfil</span>
                </div>
                <div class="contact-item" onclick="openChat('projects', 'Proyectos', 'Mis Trabajos')">
                    <span class="contact-icon"></span>
                    <span class="contact-name">Proyectos</span>
                    <span class="contact-desc">- Lo que he construido</span>
                </div>
                <div class="contact-item" onclick="openChat('stack', 'Stack Tecnologico', 'Herramientas')">
                    <span class="contact-icon"></span>
                    <span class="contact-name">Stack</span>
                    <span class="contact-desc">- Mis habilidades</span>
                </div>
                <div class="contact-item" onclick="openContactForm()">
                    <span class="contact-icon"></span>
                    <span class="contact-name">Contactar</span>
                    <span class="contact-desc">- Enviar correo</span>
                </div>
                <!-- Descarga el archivo cv.pdf que debes subir a la carpeta public/ -->
                <div class="contact-item" onclick="downloadCV()">
                    <span class="contact-icon"></span>
                    <span class="contact-name">Descargar CV</span>
                    <span class="contact-desc">- PDF adjunto</span>
                </div>
            </div>
        </div>

        <div class="contact-group">
            <div class="group-title" onclick="toggleGroup('group-offline')">Sin conexion (0)</div>
            <div id="group-offline" style="opacity:0.7"></div>
        </div>
    </div>
</div>

<!-- Primera ventana de chat (izquierda) -->
<div class="wlm-chat" id="wlm-chat-1" style="display:none;">
    <div class="resizer resizer-r"></div>
    <div class="resizer resizer-b"></div>
    <div class="resizer resizer-br"></div>
    <div class="resizer resizer-l"></div>
    <div class="resizer resizer-t"></div>

    <div class="title-bar" id="chat-drag-handle-1">
        <div class="title-bar-drag">
            <div class="title-bar-text" id="chat-title-text-1">
                <img src="https://upload.wikimedia.org/wikipedia/commons/b/b7/WLM_logo.svg" width="14">
                Chat
            </div>
        </div>
        <div class="controls">
            <button class="btn-min" onclick="minimizeChat(1)">_</button>
            <button class="btn-max" onclick="maximizeApp('wlm-chat-1')">□</button>
            <button class="btn-close" onclick="closeChat(1)">X</button>
        </div>
    </div>

    <div class="wlm-menu">
        <span>Archivo</span><span>Editar</span><span>Ver</span>
        <span>Acciones</span><span>Ayuda</span>
    </div>

    <div style="background:white; padding:5px; border-bottom:1px solid #a3bde3;
                display:flex; align-items:center; gap:10px;">
        <img src="{{aboutData.imageUrl}}" width="48" height="48"
            style="border:1px solid #ccc; padding:2px; border-radius:3px; object-fit:cover;">
        <div>
            <div style="font-weight:bold; color:#00308a;" id="chat-header-name-1">Nombre</div>
            <div style="font-size:11px; color:#666;">Dice: <span id="chat-header-sub-1">Mensaje</span></div>
        </div>
    </div>

    <div class="chat-history">
        <div class="chat-message">
            <div class="chat-sender">
                <span id="chat-msg-sender-1">Sistema</span>
                <span id="chat-time-1" style="color:#aaa; font-weight:normal; font-size:10px;">12:00</span>
            </div>
            <!-- El contenido de cada seccion se inyecta aqui por JavaScript -->
            <div class="chat-body" id="chat-content-1"></div>
        </div>
    </div>

    <div class="chat-input-area">
        <div style="display:flex; gap:8px; border-bottom:1px solid #eee;
                    padding-bottom:5px; margin-bottom:5px; color:#555;">
            <span class="material-symbols-outlined" style="font-size:18px; cursor:pointer;" title="Fuente">text_format</span>
            <span class="material-symbols-outlined" style="font-size:18px; cursor:pointer;" title="Emoticonos">mood</span>
            <span class="material-symbols-outlined" style="font-size:18px; cursor:pointer;" title="Voz">mic</span>
            <span class="material-symbols-outlined" style="font-size:18px; cursor:pointer;" title="Adjuntar">attach_file</span>
            <span class="material-symbols-outlined" style="font-size:18px; cursor:pointer;" title="Juegos">sports_esports</span>
        </div>
        <div style="flex:1; color:#aaa; font-size:11px;">Escribe un mensaje aqui...</div>
    </div>
</div>

<!-- Segunda ventana de chat (derecha) -->
<div class="wlm-chat" id="wlm-chat-2" style="display:none;">
    <div class="resizer resizer-r"></div>
    <div class="resizer resizer-b"></div>
    <div class="resizer resizer-br"></div>
    <div class="resizer resizer-l"></div>
    <div class="resizer resizer-t"></div>

    <div class="title-bar" id="chat-drag-handle-2">
        <div class="title-bar-drag">
            <div class="title-bar-text" id="chat-title-text-2">
                <img src="https://upload.wikimedia.org/wikipedia/commons/b/b7/WLM_logo.svg" width="14">
                Chat
            </div>
        </div>
        <div class="controls">
            <button class="btn-min" onclick="minimizeChat(2)">_</button>
            <button class="btn-max" onclick="maximizeApp('wlm-chat-2')">□</button>
            <button class="btn-close" onclick="closeChat(2)">X</button>
        </div>
    </div>

    <div class="wlm-menu">
        <span>Archivo</span><span>Editar</span><span>Ver</span>
        <span>Acciones</span><span>Ayuda</span>
    </div>

    <div style="background:white; padding:5px; border-bottom:1px solid #a3bde3;
                display:flex; align-items:center; gap:10px;">
        <img src="{{aboutData.imageUrl}}" width="48" height="48"
            style="border:1px solid #ccc; padding:2px; border-radius:3px; object-fit:cover;">
        <div>
            <div style="font-weight:bold; color:#00308a;" id="chat-header-name-2">Nombre</div>
            <div style="font-size:11px; color:#666;">Dice: <span id="chat-header-sub-2">Mensaje</span></div>
        </div>
    </div>

    <div class="chat-history">
        <div class="chat-message">
            <div class="chat-sender">
                <span id="chat-msg-sender-2">Sistema</span>
                <span id="chat-time-2" style="color:#aaa; font-weight:normal; font-size:10px;">12:00</span>
            </div>
            <div class="chat-body" id="chat-content-2"></div>
        </div>
    </div>

    <div class="chat-input-area">
        <div style="display:flex; gap:8px; border-bottom:1px solid #eee;
                    padding-bottom:5px; margin-bottom:5px; color:#555;">
            <span class="material-symbols-outlined" style="font-size:18px; cursor:pointer;" title="Fuente">text_format</span>
            <span class="material-symbols-outlined" style="font-size:18px; cursor:pointer;" title="Emoticonos">mood</span>
            <span class="material-symbols-outlined" style="font-size:18px; cursor:pointer;" title="Voz">mic</span>
            <span class="material-symbols-outlined" style="font-size:18px; cursor:pointer;" title="Adjuntar">attach_file</span>
            <span class="material-symbols-outlined" style="font-size:18px; cursor:pointer;" title="Juegos">sports_esports</span>
        </div>
        <div style="flex:1; color:#aaa; font-size:11px;">Escribe un mensaje aqui...</div>
    </div>
</div>

<!-- Contenido oculto de cada seccion. JS lo copia al chat cuando el usuario hace clic en un contacto -->
<div style="display:none;" id="content-about">{{> about data=aboutData}}</div>
<div style="display:none;" id="content-projects">{{> projects data=projectsData}}</div>
<div style="display:none;" id="content-stack">{{> stack data=stackData}}</div>

<!-- Toast de notificacion -->
<div id="wlm-toast" class="wlm-toast" onclick="restoreMainApp(); hideToast();">
    <div class="toast-header">
        <span>Windows Live Messenger</span>
        <span onclick="hideToast(); event.stopPropagation();" style="cursor:pointer; color:#0054E3;">X</span>
    </div>
    <div class="toast-content">
        <img src="{{aboutData.imageUrl}}" class="toast-avatar" style="object-fit:cover;">
        <div id="toast-msg">
            <b style="color:#00308a; font-size:12px;">{{siteConfig.brandName}}</b><br>
            Acaba de iniciar sesion.
        </div>
    </div>
</div>

<script>
    // Reemplaza estos tres valores con los de tu cuenta en emailjs.com
    const EMAILJS_PUBLIC_KEY  = 'TU_PUBLIC_KEY';
    const EMAILJS_SERVICE_ID  = 'TU_SERVICE_ID';
    const EMAILJS_TEMPLATE_ID = 'TU_TEMPLATE_ID';

    emailjs.init({ publicKey: EMAILJS_PUBLIC_KEY });

    const WLM_LOGO = 'https://upload.wikimedia.org/wikipedia/commons/b/b7/WLM_logo.svg';

    const app   = document.getElementById('wlm-app');
    const chat1 = document.getElementById('wlm-chat-1');
    const chat2 = document.getElementById('wlm-chat-2');
    const toast = document.getElementById('wlm-toast');
    const toastMsg = document.getElementById('toast-msg');

    // nextSlot decide en cual de las dos ventanas de chat abrir el contenido.
    // Alterna entre 1 y 2 con cada clic, para que no siempre sobreescriba la misma.
    let nextSlot = 1;

    // Todas las ventanas registradas para manejar z-index y barra de tareas
    const ALL_WINDOWS = [
        { el: app,   taskbarId: 'taskbar-item' },
        { el: chat1, taskbarId: 'taskbar-item-chat-1' },
        { el: chat2, taskbarId: 'taskbar-item-chat-2' },
    ];

    function setActiveTaskbar(elId) {
        ALL_WINDOWS.forEach(w => {
            document.getElementById(w.taskbarId)?.classList.remove('active');
        });
        const win = ALL_WINDOWS.find(w => w.el.id === elId);
        if (win) document.getElementById(win.taskbarId)?.classList.add('active');
    }

    function bringToFront(el) {
        ALL_WINDOWS.forEach(w => w.el.style.zIndex = 100);
        el.style.zIndex = 105;
        setActiveTaskbar(el.id);
    }

    // Hace que una ventana se pueda arrastrar tomandola por su barra de titulo
    function makeDraggable(el, handleId) {
        let dragging = false, ox = 0, oy = 0;
        const handle = document.getElementById(handleId);

        handle.onmousedown = (e) => {
            dragging = true;
            bringToFront(el);
            const r = el.getBoundingClientRect();
            ox = r.left - e.clientX;
            oy = r.top  - e.clientY;
            el.style.left      = r.left + 'px';
            el.style.top       = r.top  + 'px';
            el.style.transform = 'none';
        };

        document.addEventListener('mouseup',   () => dragging = false);
        document.addEventListener('mousemove', (e) => {
            if (!dragging) return;
            el.style.left = (e.clientX + ox) + 'px';
            el.style.top  = (e.clientY + oy) + 'px';
        });

        el.onmousedown = () => bringToFront(el);
    }

    makeDraggable(app,   'drag-handle');
    makeDraggable(chat1, 'chat-drag-handle-1');
    makeDraggable(chat2, 'chat-drag-handle-2');

    // Hace que una ventana se pueda redimensionar arrastrando sus bordes
    function makeResizable(el) {
        el.querySelectorAll('.resizer').forEach(r => {
            r.addEventListener('mousedown', (e) => {
                e.preventDefault();
                const rect = el.getBoundingClientRect();
                const sx = e.clientX, sy = e.clientY;
                const sw = rect.width, sh = rect.height;
                const sl = rect.left,  st = rect.top;
                el.style.left = sl + 'px'; el.style.top = st + 'px';
                el.style.transform = 'none';

                function onMove(me) {
                    const dx = me.clientX - sx, dy = me.clientY - sy;
                    if (r.classList.contains('resizer-r'))  el.style.width  = sw + dx + 'px';
                    if (r.classList.contains('resizer-b'))  el.style.height = sh + dy + 'px';
                    if (r.classList.contains('resizer-br')) { el.style.width = sw + dx + 'px'; el.style.height = sh + dy + 'px'; }
                    if (r.classList.contains('resizer-l'))  { el.style.width = sw - dx + 'px'; el.style.left   = sl + dx + 'px'; }
                    if (r.classList.contains('resizer-t'))  { el.style.height = sh - dy + 'px'; el.style.top   = st + dy + 'px'; }
                }
                function onUp() {
                    document.removeEventListener('mousemove', onMove);
                    document.removeEventListener('mouseup',   onUp);
                }
                document.addEventListener('mousemove', onMove);
                document.addEventListener('mouseup',   onUp);
            });
        });
    }

    makeResizable(app);
    makeResizable(chat1);
    makeResizable(chat2);

    // ── Controles de la ventana principal ─────────────────────────────

    function toggleMainApp() {
        const taskItem = document.getElementById('taskbar-item');
        if (app.style.display === 'none') {
            app.style.display = 'flex';
            bringToFront(app);
        } else {
            if (app.style.zIndex == 105) {
                app.style.display = 'none';
                taskItem?.classList.remove('active');
            } else {
                bringToFront(app);
            }
        }
    }

    function minimizeApp() {
        app.style.display = 'none';
        document.getElementById('taskbar-item')?.classList.remove('active');
    }

    function closeApp() {
        app.style.display = 'none';
        document.getElementById('taskbar-item').style.display = 'none';
        setTimeout(() => {
            document.getElementById('taskbar-item').style.display = 'flex';
            showToast();
        }, 1500);
    }

    function restoreMainApp() {
        app.style.display = 'flex';
        const ti = document.getElementById('taskbar-item');
        ti.style.display = 'flex';
        ti.classList.add('active');
    }

    // ── Controles de las ventanas de chat ─────────────────────────────

    // n es 1 o 2, identifica cual de las dos ventanas de chat manejar
    function toggleChat(n) {
        const chatEl   = document.getElementById('wlm-chat-' + n);
        const taskEl   = document.getElementById('taskbar-item-chat-' + n);
        if (chatEl.style.display === 'none') {
            chatEl.style.display = 'flex';
            bringToFront(chatEl);
        } else {
            if (chatEl.style.zIndex == 105) {
                chatEl.style.display = 'none';
                taskEl?.classList.remove('active');
            } else {
                bringToFront(chatEl);
            }
        }
    }

    function minimizeChat(n) {
        const chatEl = document.getElementById('wlm-chat-' + n);
        const taskEl = document.getElementById('taskbar-item-chat-' + n);
        chatEl.style.display = 'none';
        taskEl?.classList.remove('active');
    }

    function closeChat(n) {
        const chatEl = document.getElementById('wlm-chat-' + n);
        const taskEl = document.getElementById('taskbar-item-chat-' + n);
        chatEl.style.display = 'none';
        if (taskEl) taskEl.style.display = 'none';
    }

    let maximizedState = {};
    function maximizeApp(id) {
        const el = document.getElementById(id);
        if (maximizedState[id]) {
            Object.assign(el.style, maximizedState[id]);
            maximizedState[id] = null;
        } else {
            maximizedState[id] = {
                width: el.style.width || getComputedStyle(el).width,
                height: el.style.height || getComputedStyle(el).height,
                left: el.style.left, top: el.style.top,
                transform: el.style.transform
            };
            Object.assign(el.style, {
                width: '100vw', height: 'calc(100vh - 30px)',
                left: '0', top: '0', transform: 'none'
            });
        }
    }

    function toggleGroup(id) {
        const g = document.getElementById(id);
        g.style.display = g.style.display === 'none' ? 'block' : 'none';
    }

    // ── Toast ──────────────────────────────────────────────────────────

    let toastTimer;
    function showToast(html) {
        toastMsg.innerHTML = html || '<b style="color:#00308a;font-size:12px;">{{siteConfig.brandName}}</b><br>Acaba de iniciar sesion.';
        toast.classList.add('show');
        clearTimeout(toastTimer);
        toastTimer = setTimeout(hideToast, 5000);
    }
    function hideToast() { toast.classList.remove('show'); }

    // Muestra el toast de bienvenida 1 segundo despues de cargar la pagina
    setTimeout(showToast, 1000);

    // Chat

    function nowTime() {
        const d = new Date(), m = d.getMinutes();
        return d.getHours() + ':' + (m < 10 ? '0' : '') + m;
    }

    // Abre una seccion del portafolio en la siguiente ventana de chat disponible
    function openChatWindow({ title, sender, subtitle, content }) {
        document.querySelectorAll('.contact-item').forEach(i => i.classList.remove('active'));
        if (event?.currentTarget) event.currentTarget.classList.add('active');

        // Decide en cual slot abrir y alterna para la proxima vez
        const slot   = nextSlot;
        nextSlot     = slot === 1 ? 2 : 1;

        const chatEl  = document.getElementById('wlm-chat-' + slot);
        const taskEl  = document.getElementById('taskbar-item-chat-' + slot);

        document.getElementById('chat-title-text-' + slot).innerHTML =
            `<img src="${WLM_LOGO}" width="14" style="margin-right:5px;"> ${title} - Conversacion`;
        document.getElementById('chat-header-name-' + slot).innerText = title;
        document.getElementById('chat-header-sub-'  + slot).innerText = subtitle || 'Portafolio';
        document.getElementById('chat-msg-sender-'  + slot).innerText = sender   || 'Sistema';
        document.getElementById('chat-time-'        + slot).innerText = nowTime();

        document.getElementById('chat-content-' + slot).innerHTML = `
            <p style="color:#666; font-style:italic; font-size:11px; text-align:center;
                       padding:5px 0; border-bottom:1px solid #eee; margin-bottom:10px;">
                Has iniciado una conversacion con ${title}.
            </p>
            ${content}
        `;

        chatEl.style.display = 'flex';
        if (taskEl) {
            taskEl.style.display = 'flex';
            taskEl.innerHTML =
                `<img src="${WLM_LOGO}" width="14" style="margin-right:5px; filter:grayscale(1);"> ${title}`;
        }
        bringToFront(chatEl);
    }

    function openChat(sectionId, title, senderName) {
        openChatWindow({
            title,
            sender:   senderName,
            subtitle: 'Mostrando seccion de portafolio...',
            content:  document.getElementById('content-' + sectionId).innerHTML
        });
    }

    // ── Formulario de contacto ─────────────────────────────────────────

    function openContactForm() {
        openChatWindow({
            title:    'Contactarme',
            sender:   'Sistema',
            subtitle: 'Enviando un e-mail a traves de MSN...',
            // Los ids de los campos (from_name, from_email, subject, message) deben
            // coincidir exactamente con las variables del template de EmailJS
            content: `
                <form id="msn-contact-form" style="display:flex; flex-direction:column; gap:10px;">
                    <div>
                        <label style="font-size:11px; font-weight:bold; color:#00308a;">Tu Nombre:</label><br>
                        <input type="text" id="from_name" required
                            style="width:96%; border:1px solid #a3bde3; padding:4px; font-family:inherit;"
                            placeholder="Juan Perez">
                    </div>
                    <div>
                        <label style="font-size:11px; font-weight:bold; color:#00308a;">Tu Correo:</label><br>
                        <input type="email" id="from_email" required
                            style="width:96%; border:1px solid #a3bde3; padding:4px; font-family:inherit;"
                            placeholder="usuario@hotmail.com">
                    </div>
                    <div>
                        <label style="font-size:11px; font-weight:bold; color:#00308a;">Asunto:</label><br>
                        <input type="text" id="subject" required
                            style="width:96%; border:1px solid #a3bde3; padding:4px; font-family:inherit;"
                            placeholder="Oferta laboral">
                    </div>
                    <div>
                        <label style="font-size:11px; font-weight:bold; color:#00308a;">Mensaje:</label><br>
                        <textarea id="message" required rows="5"
                            style="width:96%; border:1px solid #a3bde3; padding:4px;
                                   resize:vertical; font-family:inherit;"></textarea>
                    </div>
                    <div id="f_status" style="font-size:11px; min-height:16px;"></div>
                    <button type="button" onclick="sendEmail()"
                        style="background:linear-gradient(to bottom,#dbe9f9 0%,#b2cfee 100%);
                               border:1px solid #00308a; padding:5px 15px; cursor:pointer;
                               font-weight:bold; border-radius:3px; color:#00308a; align-self:flex-end;">
                        Enviar (Zumbido)
                    </button>
                </form>
            `
        });
    }

    function sendEmail() {
        const name    = document.getElementById('from_name')?.value.trim();
        const email   = document.getElementById('from_email')?.value.trim();
        const subject = document.getElementById('subject')?.value.trim();
        const message = document.getElementById('message')?.value.trim();
        const status  = document.getElementById('f_status');

        if (!name || !email || !subject || !message) {
            status.style.color = 'red';
            status.innerText = 'Por favor completa todos los campos.';
            return;
        }

        status.style.color = '#555';
        status.innerText = 'Enviando...';

        // Las claves del objeto deben coincidir con las variables del template de EmailJS:
        // {{from_name}}, {{from_email}}, {{subject}}, {{message}}
        emailjs.send(EMAILJS_SERVICE_ID, EMAILJS_TEMPLATE_ID, {
            from_name,
            from_email: email,
            subject,
            message
        }).then(() => {
            status.style.color = 'green';
            status.innerText = 'Mensaje enviado correctamente.';
            document.getElementById('msn-contact-form').reset();
            showToast('<b style="color:#00308a;font-size:12px;">Mensaje enviado!</b><br>Me pondre en contacto pronto.');
        }).catch((err) => {
            console.error('EmailJS error:', err);
            status.style.color = 'red';
            status.innerText = 'Error al enviar. Revisa la consola.';
        });
    }

    // ── CV ─────────────────────────────────────────────────────────────

    // Descarga el archivo cv.pdf que debe estar en la carpeta public/
    function downloadCV() {
        const a = document.createElement('a');
        a.href     = '/cv.pdf';
        a.download = 'CV.pdf';
        a.click();
    }

    // ── Estado inicial al cargar la pagina ────────────────────────────

    // Abre la seccion "Sobre Mi" automaticamente en la ventana de chat 1
    // con un tamano comodo para ver el contenido sin necesidad de hacer scroll
    window.addEventListener('load', () => {
        const content = document.getElementById('content-about').innerHTML;

        chat1.style.display  = 'flex';
        chat1.style.width    = '520px';
        chat1.style.height   = '480px';
        // La posicionamos a la izquierda del WLM principal
        chat1.style.left     = '20px';
        chat1.style.top      = '60px';
        chat1.style.transform = 'none';

        document.getElementById('chat-title-text-1').innerHTML =
            `<img src="${WLM_LOGO}" width="14" style="margin-right:5px;"> Sobre Mi - Conversacion`;
        document.getElementById('chat-header-name-1').innerText = 'Sobre Mi';
        document.getElementById('chat-header-sub-1').innerText  = 'Mostrando seccion de portafolio...';
        document.getElementById('chat-msg-sender-1').innerText  = '{{siteConfig.brandName}}';
        document.getElementById('chat-time-1').innerText        = nowTime();
        document.getElementById('chat-content-1').innerHTML     = `
            <p style="color:#666; font-style:italic; font-size:11px; text-align:center;
                       padding:5px 0; border-bottom:1px solid #eee; margin-bottom:10px;">
                Has iniciado una conversacion con Sobre Mi.
            </p>
            ${content}
        `;

        const taskEl = document.getElementById('taskbar-item-chat-1');
        if (taskEl) {
            taskEl.style.display = 'flex';
            taskEl.innerHTML = `<img src="${WLM_LOGO}" width="14" style="margin-right:5px; filter:grayscale(1);"> Sobre Mi`;
        }

        // Proxima seccion que se abra usara el slot 2
        nextSlot = 2;

        bringToFront(chat1);
    });
</script>